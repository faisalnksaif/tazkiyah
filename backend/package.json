{
  "name": "tazkiyah-backend",
  "version": "1.0.0",
  "description": "Backend API for Tazkiyah - group growth challenge tracker",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node seed/seed.js",
    "test": "jest --runInBand",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop tazkiyah-backend",
