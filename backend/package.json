    "moment": "^2.30.1",
    "mongoose": "^8.4.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.2.0",
    "nodemon": "^3.1.4",
    "pm2": "^7.0.3",
    "supertest": "^7.0.0"
  }
}
